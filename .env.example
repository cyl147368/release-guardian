# Release Guardian Configuration

# Server
PORT=3000
HOST=127.0.0.1
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Authentication (comma-separated API keys)
API_KEYS=

# CORS
CORS_ORIGIN=*

# Security Headers (set to "false" to disable)
SECURITY_HEADERS=true
